# Copy to .env and adjust.

# Working directories
WORK_DIR=./work
OUTPUT_DIR=./output

# MLX LLM server (start with: mlx_lm.server --model Qwen/Qwen3-235B-A22B-MLX-4bit --port 8080)
LLM_SERVER_URL=http://127.0.0.1:8080/v1
LLM_MODEL=Qwen/Qwen3-235B-A22B-MLX-4bit
LLM_TIMEOUT_SEC=120

# Transcription model
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# Detection thresholds (tune per creator after 5-10 sessions)
FREEZE_DB=-50
FREEZE_MIN_SEC=2.0
SILENCE_DB=-30
SILENCE_MIN_SEC=2.0
MOTION_THRESHOLD=0.02
MOTION_BLUR=9
MOTION_WIDTH=400

# Dead-zone classification (seconds)
CUT_MIN_SEC=10.0
SPEED_8X_MIN_SEC=3.0

# Render
VIDEO_BITRATE=12M
VIDEO_RES_W=1920
VIDEO_RES_H=1080
VIDEO_FPS=30

# Loudness (YouTube ingest targets)
LOUDNESS_TARGET=-14.0
TRUE_PEAK=-1.5
LOUDNESS_RANGE=11.0
